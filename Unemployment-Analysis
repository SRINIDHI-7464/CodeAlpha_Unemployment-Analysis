import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns


df = pd.read_csv("Unemployment in India.csv")
print(df.head())
print(df.info())
print(df.isnull().sum())

df.columns = ['Region', 'Date', 'Frequency', 'Estimated Unemployment Rate',
              'Estimated Employed', 'Estimated Labour Participation Rate', 'Area']

df = df.dropna()

df['Date'] = pd.to_datetime(df['Date'])


print("Duplicate Rows:", df.duplicated().sum())

print(df.describe())

plt.figure(figsize=(8,5))
sns.histplot(df['Estimated Unemployment Rate'], bins=20, kde=True)
plt.title("Distribution of Unemployment Rate")
plt.xlabel("Unemployment Rate")
plt.ylabel("Count")
plt.show()

plt.figure(figsize=(15,6))
sns.barplot(x='Region', y='Estimated Unemployment Rate', data=df)
plt.xticks(rotation=90)
plt.title("State-wise Unemployment Rate")
plt.show()


monthly = df.groupby(df['Date'].dt.month)['Estimated Unemployment Rate'].mean()

plt.figure(figsize=(8,5))
monthly.plot(marker='o')
plt.title("Monthly Unemployment Trend")
plt.xlabel("Month")
plt.ylabel("Average Unemployment Rate")
plt.grid()
plt.show()


covid_data = df[df['Date'].dt.year == 2020]

plt.figure(figsize=(10,5))
sns.lineplot(x='Date', y='Estimated Unemployment Rate', data=covid_data)
plt.xticks(rotation=45)
plt.title("Covid-19 Impact on Unemployment")
plt.show()


corr = df[['Estimated Unemployment Rate',
           'Estimated Employed',
           'Estimated Labour Participation Rate']].corr()

plt.figure(figsize=(8,5))
sns.heatmap(corr, annot=True, cmap='coolwarm')
plt.title("Correlation Matrix")
plt.show()


state_unemployment = df.groupby('Region')['Estimated Unemployment Rate'].mean()
print(state_unemployment)

print("\nINSIGHTS:")
print("1. Covid-19 caused unemployment to rise sharply.")
print("2. Some states have higher unemployment rates than others.")
print("3. Monthly trends show fluctuations in unemployment.")
print("4. Employment and unemployment are negatively correlated.")
